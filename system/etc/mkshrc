# Define the standard nano function
nano() {
    su -c "nano -A -D -F -G -I -L -M -S -U -Z -a -q '-_' '-/'"
}



# Functions which I'm gonna count as aliases
getperms() {
    [ -z "$1" ] && { echo "Usage: getperms <package_name>"; return 1; }
    pm get-privapp-permissions "$1" | sed 's/, /\n/g'
}

getdenyperms() {
    [ -z "$1" ] && { echo "Usage: getdenyperms <package_name>"; return 1; }
    pm get-privapp-deny-permissions "$1" | sed 's/, /\n/g'
}
