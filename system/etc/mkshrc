: ${TERM:=xterm-256color} ${HOME:=/} ${MKSH:=/system/bin/sh} ${HOSTNAME:=android}
: ${SHELL:=$MKSH}

export TERM HOME MKSH HOSTNAME SHELL USER PATH
export TERMINFO=/system/usr/share/terminfo

if (( USER_ID == 0 )); then
    PS1='$HOSTNAME@$USER:${PWD:-?} # '
else
    PS1='$HOSTNAME@$USER:${PWD:-?} $ '
fi

############################################################

IS_INTERACTIVE_SHELL=0
if [ -t 0 ]; then
    IS_INTERACTIVE_SHELL=1
fi

if (( IS_INTERACTIVE_SHELL )) && [ "$ENV_CLEANSED" != "1" ]; then
    export ENV_CLEANSED=1

    if [ -x /data/adb/ksu/bin/su ]; then
        SU_CMD="/data/adb/ksu/bin/su"
    elif [ -x /data/adb/ap/bin/su ]; then
        SU_CMD="/data/adb/ap/bin/su"
    elif command -v su >/dev/null 2>&1; then
        SU_CMD="$(command -v su)"
    elif [ -x /system/bin/su ]; then
        SU_CMD="/system/bin/su"
    elif [ -x /system/xbin/su ]; then
        SU_CMD="/system/xbin/su"
    else
        SU_CMD="su"
    fi

    cd /sdcard 2>/dev/null || cd /storage/emulated/0 2>/dev/null || cd /data/local/tmp 2>/dev/null

    exec env -i \
        PATH=/system/bin:/system/xbin:/product/bin:/apex/com.android.runtime/bin:/data/adb/ksu/bin:/data/adb/ap/bin \
        TERM="${TERM:-xterm-256color}" \
        HOME=/data \
        SHELL=/system/bin/sh \
        USER=root \
        ENV_CLEANSED=1 \
        LD_PRELOAD="" \
        "$SU_CMD" -m
fi

