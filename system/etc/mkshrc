# 1. BUSYBOX universal wrapper function
_bb_cmd() {
    # ${0##*/} extracts the command name from the alias
    busybox "${0##*/}" "$@"
}

# 2. Define the list of tools
BB_TOOLS="vi less tree diff patch tar find xargs awk grep nc traceroute wget acpid adjtimex arping ascii bbconfig beep blkdiscard brctl bunzip2 bzcat bzip2 cal chat chattr chcon chrt chvt conspy cpio crond crontab cttyhack dc deallocvt depmod devmem dhcprelay dnsd dnsdomainname dos2unix dumpkmap dumpleases ed eject ether-wake expand factor fakeidentd fallocate fatattr fbset fbsplash fdflush fdformat fgconsole findfs flash_eraseall flash_lock flash_unlock flock freeramdisk fsck.minix fsfreeze fstrim ftpd hd hexedit hush hwclock ifdown ifenslave ifplugd ifup inetd inotifyd insmod ionice ipaddr ipcalc ipcrm ipcs iplink ipneigh iproute iprule iptunnel kbd_mode killall5 link loadfont loadkmap logread lsattr lspci lsscsi lzcat lzma lzop lzopcat makedevs makemime mesg microcom mim mkfifo mknod modinfo mpstat nameif nanddump nandwrite nbd-client nmeter nohup nologin nsenter nuke openvt partprobe pgrep pipe_progress pkill pmap popmaildir powertop pscan pstree pwdx raidautorun rdate rdev readprofile reformime renice resize resume rev rfkill rmmod rtcwake run-init run-parts runcon rx script scriptreplay seedrng selinuxenabled seq sestatus setconsole setenforce setfattr setfont setkeycodes setlogcons setpriv setserial setsid setuidgid shred shuf slattach smemcap ssl_client start-stop-daemon svc svok tac tcpsvd telnet telnetd tftp tftpd ts tsort ttysize tunctl ubiattach ubidetach ubimkvol ubirename ubirmvol ubirsvol ubiupdatevol udhcpc6 udhcpd udpsvd uevent uncompress unexpand unix2dos unlzma unlzop unshare unxz usleep uudecode uuencode vconfig volname watchdog whois xxd xz xzcat zcat zcip"

