# A cleaner, more robust version of your alias                                                                         
killpac() {                                                                                                            
    if [ -z "$1" ]; then                                                                                               
        echo "Usage: killpac <process_name>"                                                                           
    else                                                                                                               
        # pkill handles the PID lookup and killing in one step                                                         
        pkill -f "$1"                                                                                                  
    fi                                                                                                                 
}   
